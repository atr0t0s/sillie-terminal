{
  "name": "sillie",
  "version": "0.1.0",
  "description": "Terminal in your browser",
  "bin": {
    "sillie": "./bin/sillie.js"
  },
  "scripts": {
    "dev:server": "node server/index.js",
    "dev:client": "cd client && npx vite",
    "build:client": "cd client && npx vite build",
    "test": "node --test tests/**/*.test.js",
    "prepublishOnly": "cd client && npm install && npx vite build"
  },
  "files": [
    "bin/",
    "server/",
    "client/dist/",
    "scripts/"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "node-pty": "^1.2.0-beta.11",
    "ws": "^8.19.0"
  }
}
